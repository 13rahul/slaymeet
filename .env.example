# App
SITE_URL=http://localhost:8080
SITE_NAME=SlayMeet
APP_TIMEZONE=UTC
SLAYMEET_COMPANY_ID=1

# Database (docker-compose defaults)
DB_HOST=db
DB_NAME=slaymeet
DB_USER=slaymeet
DB_PASS=slaymeet

# LiveKit (must match deploy/livekit/livekit.yaml keys)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=slaymeet_api_key
LIVEKIT_API_SECRET=slaymeet_sec_9876543210fedcbaabcdef0123456789

# Security — change before production
SLAYMEET_BOT_SECRET=change-me-to-a-long-random-string
DAEMON_TOKEN=change-me-daemon-token
CRON_SECRET=change-me-cron-secret

# Teena AI (brain)
GEMINI_API_KEY=

# Optional brand context injected into Teena system prompt
SLAYMEET_BRAND_NAME=Your Team
SLAYMEET_BRAND_CONTEXT=

# TTS (Piper default)
SLAYMEET_TTS_ENGINE=piper
SLAYMEET_PIPER_HOME=storage/piper
SLAYMEET_PIPER_VOICE=en_US-amy-medium

# Optional TURN for corporate NAT
# SLAYMEET_TURN_HOST=
# SLAYMEET_TURN_USER=
# SLAYMEET_TURN_PASS=
